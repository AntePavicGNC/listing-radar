// Listing Radar — Datenmodell (SPEC §4, finale Version)
// Alle Quellen werden auf EIN Schema gemappt. Vertical-spezifische Felder liegen
// als nullbare Spalten im Listing-Modell (single table), unterschieden über `vertical`.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Source {
  njuskalo
  indexoglasi
  autoscout24
  mobilede
  autohero
}

enum Vertical {
  house
  land
  car
}

enum ListingStatus {
  active
  gone
}

enum Fuel {
  diesel
  petrol
  hybrid_petrol
  hybrid_diesel
  electric
  other
}

enum Transmission {
  manual
  automatic
}

enum RenovationNeeded {
  none
  light
  moderate
  heavy
}

enum InfotainmentGeneration {
  latest
  previous
  older
  unknown
}

enum BodyType {
  limousine
  sportback
  suv
  suv_coupe
  kombi
  other
}

model Listing {
  id              String        @id // Hash aus source + sourceListingId
  source          Source
  sourceListingId String
  vertical        Vertical
  url             String
  title           String
  priceEur        Int
  images          String[] // Bild-URLs vom Portal-CDN
  description     String?

  // Ort (flach gespeichert, damit nach Stadt/Region filterbar)
  locationRaw    String
  locationCity   String?
  locationRegion String?
  lat            Float?
  lng            Float?

  postedAt    DateTime?
  firstSeenAt DateTime      @default(now())
  lastSeenAt  DateTime      @default(now())
  status      ListingStatus @default(active)

  // Preis-Handling (SPEC §9): Fake-Preis-Erkennung / "Preis auf Anfrage"
  displayPriceEur     Int? // echter Preis nach Erkennung; Filter/Score rechnen hiermit
  priceOnRequest      Boolean @default(false)
  aiFairPriceEstimate Int? // KI-Schätzung, nur bei priceOnRequest

  // Scoring (SPEC §5): EIN Gesamt-Score + Begründung + manueller Override
  score             Int    @default(0) // 0-100, berechnet
  scoreBreakdown    Json? // [{ label, points }], Plus-/Minuspunkte
  scoreOverride     Int? // manuell gesetzt, übersteht Re-Scrapes
  scoreOverrideNote String?
  locationScore     Int? // 1-10 aus der Ortstabelle (Haus + Grundstück)

  aiImageScore Int? // 0-100, nur Häuser/Grundstücke
  aiImageNotes String?

  dedupeKey String? // gerundeter Preis + Fläche/km + Stadt (SPEC §6)

  // --- Haus ---
  areaLivingM2          Float?
  areaPlotM2            Float?
  rooms                 Int? // reine Wohnräume ohne Küche/Bad (SPEC §4)
  bathroomCount         Int?
  yearBuilt             Int?
  yearRenovated         Int?
  hasGarden             Boolean?
  hasPool               Boolean?
  hasAuxiliaryBuilding  Boolean? // Sommerküche, Gästehaus
  hasParkingSpot        Boolean?
  hasGarage             Boolean?
  hasAirConditioning    Boolean?
  heatingType           String?
  renovationNeeded      RenovationNeeded?
  hasSeaViewLikely      Boolean?
  looksLikeTouristRental Boolean?
  pricePerLivingM2      Float? // abgeleitet
  pricePerPlotM2        Float? // abgeleitet

  // --- Grundstück ---
  zoningStated               Boolean? // nennt Portal/Beschreibung überhaupt eine Zonierung?
  zoningConfirmedBuildingLand Boolean? // Baugrund klar bestätigt?
  pricePerM2                 Float? // abgeleitet, auf Basis displayPriceEur

  // --- Auto ---
  make                    String?
  model                   String?
  variant                 String?
  firstRegistrationYear   Int?
  firstRegistrationMonth  Int?
  mileageKm               Int?
  fuel                    Fuel?
  rangeKm                 Int? // nur bei electric relevant (>= 500)
  transmission            Transmission?
  powerPs                 Int?
  bodyType                BodyType?
  distanceFromIsmaningKm  Float? // abgeleitet
  hasAdaptiveCruiseControl Boolean?
  hasParkingCamera        Boolean?
  infotainmentGeneration  InfotainmentGeneration?
  monthlyFinancingEur     Int? // abgeleitet (Finanzierungs-Rechner)

  raw Json? // Original-Datensatz der Quelle

  priceHistory PriceHistory[]
  userFlag     UserFlag?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, sourceListingId])
  @@index([vertical, status])
  @@index([dedupeKey])
  @@index([vertical, score])
}

model PriceHistory {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  priceEur  Int

  @@index([listingId])
}

// Eigene Tabelle, damit Re-Imports die User-Flags NICHT überschreiben (SPEC §4).
// Flags gelten gemeinsam für alle Nutzer (SPEC §2).
model UserFlag {
  listingId String   @id
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  favorite  Boolean  @default(false)
  hidden    Boolean  @default(false) // "raus"
  seen      Boolean  @default(false)
  updatedAt DateTime @updatedAt
}
