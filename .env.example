# Listing Radar — Environment-Variablen (Vorlage)
# Lokal:  Werte in apps/web/.env eintragen (ist via .gitignore ausgeschlossen).
# Vercel: dieselben Variablen als Project Environment Variables setzen.

# --- Apify (ab Meilenstein 3) ---
APIFY_TOKEN=

# --- Webhook-Schutz für POST /api/ingest (ab Meilenstein 3) ---
INGEST_SECRET=

# --- Supabase Postgres (Prisma) ---
# DATABASE_URL = gepoolte Verbindung (Transaction Pooler, Port 6543) — App-Laufzeit
# DIRECT_URL   = direkte Verbindung (Port 5432) — Prisma-Migrationen (ab Meilenstein 2)
DATABASE_URL=
DIRECT_URL=

# --- Privater Zugriffsschutz (Proxy + Login) ---
APP_PASSWORD=

# --- KI: Bildbewertung & Auto-Recherche (ab Meilenstein 8) ---
ANTHROPIC_API_KEY=

# --- App-URL (lokal http://localhost:3000, auf Vercel die Deploy-URL) ---
NEXT_PUBLIC_APP_URL=
